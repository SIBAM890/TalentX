# TalentX Environment Variables
# Copy this file to .env and fill in your values

# App Settings
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Model Settings
SENTENCE_BERT_MODEL=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
USE_GPU=false

# Frontend Settings
FRONTEND_PORT=8501
API_BASE_URL=http://localhost:8000

# Optional: OpenAI (for future enhancement)
# OPENAI_API_KEY=your_key_here
